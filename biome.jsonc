{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	},
	"assist": {
		"actions": {
			"recommended": true,
			"source": {
				"noDuplicateClasses": "on",
				"organizeImports": "on"
			}
		},
		"enabled": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!src/routeTree.gen.ts", "!src/styles/app.css"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"domains": {
			"test": "all",
			"types": "all"
		},
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}

{
	"name": "pi-telemetry-web",
	"version": "0.1.0",
	"description": "Self-hosted telemetry dashboard companion for pi-telemetry-minimal",
	"type": "module",
	"sideEffects": false,
	"author": "drsh4dow <daniel.morettiv@gmail.com> (https://github.com/drsh4dow)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/drsh4dow/pi-telemetry-web.git"
	},
	"bugs": {
		"url": "https://github.com/drsh4dow/pi-telemetry-web/issues"
	},
	"homepage": "https://github.com/drsh4dow/pi-telemetry-web#readme",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun run build:docker",
		"build:docker": "NITRO_PRESET=bun bun --bun vite build",
		"build:vercel": "NITRO_PRESET=vercel bun --bun vite build",
		"start": "bun .output/server/index.mjs",
		"migrate": "bun scripts/migrate.ts",
		"reset-password": "bun scripts/reset-password.ts",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"keywords": [
		"pi",
		"telemetry",
		"dashboard",
		"tanstack-start",
		"sqlite",
		"self-hosted"
	],
	"dependencies": {
		"@base-ui/react": "^1.0.0-beta.4",
		"@better-auth/drizzle-adapter": "^1.4.7",
		"@fontsource-variable/geist": "^5.2.8",
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@libsql/client": "^0.17.3",
		"@t3-oss/env-core": "^0.13.8",
		"@tanstack/react-router": "^1.168.25",
		"@tanstack/react-start": "^1.167.50",
		"better-auth": "^1.4.7",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"lucide-react": "^0.555.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"recharts": "^3.4.1",
		"tailwind-merge": "^3.4.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.13",
		"@types/node": "^25.0.0",
		"@types/react": "^19.0.8",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react": "^6.0.1",
		"nitro": "^3.0.260311-beta",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.0"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"esbuild"
	]
}

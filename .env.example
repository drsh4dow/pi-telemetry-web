# Required in production. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of this app, e.g. https://pi-telemetry.example.com
BETTER_AUTH_URL=http://localhost:3000

# Docker/Railway should mount this directory as persistent storage.
DATA_DIR=./data
# DB_PATH=/data/pi-telemetry-web.sqlite

# Optional. If absent, the app creates and stores one ingest token.
# PI_TELEMETRY_INGEST_TOKEN=

PORT=3000

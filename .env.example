# Required in production. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of this app, e.g. https://pi-telemetry.example.com
BETTER_AUTH_URL=http://localhost:3000

# Database backend: local or turso.
DATABASE_BACKEND=local

# Local backend. Docker/Railway should mount this directory as persistent storage.
DATA_DIR=./data
# DB_PATH=/data/pi-telemetry-web.sqlite

# Turso backend. Required when DATABASE_BACKEND=turso.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=

# Run app-owned migrations during startup. Set false when migrations are managed separately.
MIGRATE_ON_STARTUP=true

# Optional. If absent, the app creates and stores one ingest token.
# PI_TELEMETRY_INGEST_TOKEN=

PORT=3000
